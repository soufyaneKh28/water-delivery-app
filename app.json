{
  "expo": {
    "name": "Water Delivery App",
    "slug": "water-delivery-app",
    "scheme": "water-delivery-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.waterdelivery.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show nearby water delivery options.",
        "UIBackgroundModes": ["remote-notification"] 
      },
      "entitlements": {
        "aps-environment": "development", 
        "com.apple.security.application-groups": [
          "group.${ios.bundleIdentifier}.onesignal" 
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.waterdelivery.app"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "339e3c5a-4df8-473d-b686-755557cd5877"
      }
    },
    "owner": "soufyanekh28",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/339e3c5a-4df8-473d-b686-755557cd5877"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ]
    ]
  }
}
